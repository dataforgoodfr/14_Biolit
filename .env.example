# Source
BIOLIT_API_URL=https://example.org/wp-json/biolit/v1/observations?token=change-me

# PostgreSQL
POSTGRES_USER=biolit
POSTGRES_PASSWORD=change-me
POSTGRES_DB=biolit
POSTGRES_PORT=5432

# Stockage temporaire MinIO/S3
MINIO_ROOT_USER=biolit
MINIO_ROOT_PASSWORD=change-me
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=biolit-temporary
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000

# Label Studio : démarrer une première fois, puis copier le jeton API ici
LABEL_STUDIO_USERNAME=admin@biolit.local
LABEL_STUDIO_PASSWORD=change-me
LABEL_STUDIO_API_KEY=change-me-after-first-login
LABEL_STUDIO_PUBLIC_URL=http://localhost:8089
LABEL_STUDIO_PORT=8089

# Metabase : mettre le nom du volume existant et passer external à true si besoin
METABASE_PORT=3000
METABASE_VOLUME_NAME=biolit_metabase_data
METABASE_VOLUME_EXTERNAL=false
METABASE_IMAGE=metabase/metabase:latest

# Worker
PIPELINE_BATCH_SIZE=20
PIPELINE_INTERVAL_SECONDS=300
PROCESSING_STALE_MINUTES=30
ML_DEVICE=cpu
